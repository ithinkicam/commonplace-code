  {
    "slug": "text_the_liturgy_of_the_palms_anglican",
    "name": "Text (The Liturgy of the Palms)",
    "liturgy_name": "Palm Sunday",
    "liturgy_slug": "palm_sunday_anglican",
    "kind": "prayer-body",
    "body_text": "Assist us mercifully with your help, O Lord God of our salvation, that we may enter with joy upon the contemplation of those mighty acts, whereby you have given us life and immortality; through Jesus Christ our Lord. Amen.",
    "section": "The Liturgy of the Palms",
    "source_file": "palmsunday.html",
    "page_number": null,
    "raw_metadata": {
      "liturgy_name": "Palm Sunday",

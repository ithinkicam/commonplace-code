    "name": "Psalm 51 verse 4",
    "liturgy_name": "Ash Wednesday",
    "liturgy_slug": "ash_wednesday_anglican",
    "kind": "psalm-verse",
    "body_text": "Against you only have I sinned *\nand done what is evil in your sight.",
    "section": "Ash Wednesday",
    "source_file": "ashwed.html",
    "page_number": 265,
    "raw_metadata": {
      "liturgy_name": "Ash Wednesday",
      "liturgy_slug": "ash_wednesday_anglican",
      "section": "Ash Wednesday",
      "kind": "psalm-verse",
      "source_file": "ashwed.html",

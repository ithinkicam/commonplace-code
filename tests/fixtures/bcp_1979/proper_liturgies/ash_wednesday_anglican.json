    "name": "Psalm 51 verse 3",
    "liturgy_name": "Ash Wednesday",
    "liturgy_slug": "ash_wednesday_anglican",
    "kind": "psalm-verse",
    "body_text": "For I know my transgressions, *\nand my sin is ever before me.",
    "section": "Ash Wednesday",
    "source_file": "ashwed.html",
    "page_number": 265,
    "raw_metadata": {
      "liturgy_name": "Ash Wednesday",
      "liturgy_slug": "ash_wednesday_anglican",

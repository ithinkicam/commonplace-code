    "liturgy_name": "Ash Wednesday",
    "liturgy_slug": "ash_wednesday_anglican",
    "kind": "psalm-verse",
    "body_text": "Indeed, I have been wicked from my birth, *\na sinner from my mother's womb.",
    "section": "Ash Wednesday",
    "source_file": "ashwed.html",
    "page_number": 265,
    "raw_metadata": {
      "liturgy_name": "Ash Wednesday",
      "liturgy_slug": "ash_wednesday_anglican",

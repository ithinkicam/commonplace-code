    "liturgy_name": "Ash Wednesday",
    "liturgy_slug": "ash_wednesday_anglican",
    "kind": "psalm-verse",
    "body_text": "Purge me from my sin, and I shall be pure; *\nwash me, and I shall be clean indeed.",
    "section": "Ash Wednesday",
    "source_file": "ashwed.html",
    "page_number": 265,
    "raw_metadata": {
      "liturgy_name": "Ash Wednesday",
      "liturgy_slug": "ash_wednesday_anglican",

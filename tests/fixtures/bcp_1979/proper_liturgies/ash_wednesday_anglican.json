    "name": "Psalm 51 verse 5",
    "liturgy_name": "Ash Wednesday",
    "liturgy_slug": "ash_wednesday_anglican",
    "kind": "psalm-verse",
    "body_text": "And so you are justified when you speak *\nand upright in your judgment.",
    "section": "Ash Wednesday",
    "source_file": "ashwed.html",
    "page_number": 265,
    "raw_metadata": {
      "liturgy_name": "Ash Wednesday",
      "liturgy_slug": "ash_wednesday_anglican",

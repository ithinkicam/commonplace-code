  {
    "slug": "text_the_solemn_collects_anglican",
    "name": "Text (The Solemn Collects)",
    "liturgy_name": "Good Friday",
    "liturgy_slug": "good_friday_anglican",
    "kind": "prayer-body",
    "body_text": "Gracious God, the comfort of all who sorrow, the strength of all who suffer: Let the cry of those in misery and need come to you, that they may find your mercy present with them in all their afflictions; and give us, we pray, the strength to serve them for the sake of him who suffered for us, your Son Jesus Christ our Lord. Amen. Let us pray for all who have not received the Gospel of Christ; For those who have never heard the word of salvation For those who have lost their faith For those hardened by sin or indifference For the contemptuous and the scornful For those who are enemies of the cross of Christ and persecutors of his disciples For those who in the name of Christ have persecuted others That God will open their hearts to the truth, and lead them to faith and obedience.",
    "section": "The Solemn Collects",
    "source_file": "friday.html",
    "page_number": 278,
    "raw_metadata": {
      "liturgy_name": "Good Friday",
      "liturgy_slug": "good_friday_anglican",
      "section": "The Solemn Collects",
      "kind": "prayer-body",
      "source_file": "friday.html",
      "page_number": 278,
      "speaker": null,
      "psalm_number": null,
      "verse_number": null,
      "is_optional": false
    }
  },
  {
    "slug": "rubric_the_solemn_collects_anglican",
    "name": "Rubric (The Solemn Collects)",
    "liturgy_name": "Good Friday",

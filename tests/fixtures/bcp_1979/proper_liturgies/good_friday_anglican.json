    "liturgy_slug": "good_friday_anglican",
    "kind": "prayer-body",
    "body_text": "Almighty God, kindle, we pray, in every heart the true love of peace, and guide with your wisdom those who take counsel for the nations of the earth; that in tranquility your dominion may",
    "section": "The Solemn Collects",
    "source_file": "friday.html",
    "page_number": 277,

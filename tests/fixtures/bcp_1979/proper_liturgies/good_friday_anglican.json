  {
    "slug": "text_the_solemn_collects_anglican",
    "name": "Text (The Solemn Collects)",
    "liturgy_name": "Good Friday",
    "liturgy_slug": "good_friday_anglican",
    "kind": "prayer-body",
    "body_text": "Almighty and everlasting God, by whose Spirit the whole body of your faithful people is governed and sanctified: Receive our supplications and prayers which we offer before you for all members of your holy Church, that in their vocation and ministry they may truly and devoutly serve you; through our Lord and Savior Jesus Christ. Amen. Let us pray for all nations and peoples of the earth, and for those in authority among them;",
    "section": "The Solemn Collects",
    "source_file": "friday.html",
    "page_number": 277,
    "raw_metadata": {
      "liturgy_name": "Good Friday",
      "liturgy_slug": "good_friday_anglican",
      "section": "The Solemn Collects",
      "kind": "prayer-body",
      "source_file": "friday.html",
      "page_number": 277,
      "speaker": null,
      "psalm_number": null,
      "verse_number": null,
      "is_optional": false
    }
  },
  {
    "slug": "text_the_solemn_collects_anglican",
    "name": "Text (The Solemn Collects)",
    "liturgy_name": "Good Friday",
    "liturgy_slug": "good_friday_anglican",
    "kind": "prayer-body",
    "body_text": "For N., the President of the United States For the Congress and the Supreme Court For the Members and Representatives of the United Nations For all who serve the common good",
    "section": "The Solemn Collects",
    "source_file": "friday.html",
    "page_number": 277,
    "raw_metadata": {
      "liturgy_name": "Good Friday",
      "liturgy_slug": "good_friday_anglican",

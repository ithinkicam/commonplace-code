  {
    "slug": "text_the_solemn_collects_anglican",
    "name": "Text (The Solemn Collects)",
    "liturgy_name": "Good Friday",
    "liturgy_slug": "good_friday_anglican",
    "kind": "prayer-body",
    "body_text": "Dear People of God: Our heavenly Father sent his Son into the world, not to condemn the world, but that the world through him might be saved; that all who believe in him might be delivered from the power of sin and death, and become heirs with him of everlasting life. We pray, therefore, for people everywhere according to their needs.",
    "section": "The Solemn Collects",
    "source_file": "friday.html",
    "page_number": 276,
    "raw_metadata": {
      "liturgy_name": "Good Friday",
      "liturgy_slug": "good_friday_anglican",
      "section": "The Solemn Collects",
      "kind": "prayer-body",
      "source_file": "friday.html",
      "page_number": 276,
      "speaker": null,
      "psalm_number": null,
      "verse_number": null,
      "is_optional": false
    }
  },
  {
    "slug": "rubric_the_solemn_collects_anglican",
    "name": "Rubric (The Solemn Collects)",
    "liturgy_name": "Good Friday",
    "liturgy_slug": "good_friday_anglican",
    "kind": "rubric",
    "body_text": "In the biddings which follow, the indented portions may be adapted by addition or omission, as appropriate, at the discretion of the Celebrant. The people may be directed to stand or kneel. The biddings may be read by a Deacon or other person appointed. The Celebrant says the Collects.",
    "section": "The Solemn Collects",
    "source_file": "friday.html",
    "page_number": 276,
    "raw_metadata": {
      "liturgy_name": "Good Friday",
      "liturgy_slug": "good_friday_anglican",
      "section": "The Solemn Collects",
      "kind": "rubric",
      "source_file": "friday.html",
      "page_number": 276,
      "speaker": null,
      "psalm_number": null,
      "verse_number": null,
      "is_optional": false
    }
  },
  {
    "slug": "text_the_solemn_collects_anglican",
    "name": "Text (The Solemn Collects)",
    "liturgy_name": "Good Friday",
    "liturgy_slug": "good_friday_anglican",
    "kind": "prayer-body",
    "body_text": "Let us pray for the holy Catholic Church of Christ throughout the world;",
    "section": "The Solemn Collects",
    "source_file": "friday.html",
    "page_number": 277,
    "raw_metadata": {
      "liturgy_name": "Good Friday",
      "liturgy_slug": "good_friday_anglican",

    <key>StandardOutPath</key>
    <string>/Users/cameronlewis/Library/Logs/commonplace-library-watch.out.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/cameronlewis/Library/Logs/commonplace-library-watch.err.log</string>
</dict>
</plist>
